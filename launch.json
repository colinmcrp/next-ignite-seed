{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "🚀 Dev Server (npm run dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_OPTIONS": "--inspect"
      },
      "presentation": {
        "hidden": false,
        "group": "server",
        "order": 1
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🏗️ Build & Start (Production)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "postDebugTask": "npm: start",
      "presentation": {
        "hidden": false,
        "group": "server",
        "order": 2
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🧪 Run Tests",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["test"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "hidden": false,
        "group": "testing",
        "order": 1
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🔍 Run Tests (Watch Mode)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test:watch"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "hidden": false,
        "group": "testing",
        "order": 2
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🗄️ Prisma Studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:studio"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "hidden": false,
        "group": "database",
        "order": 1
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🔄 Database Migration",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:migrate"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "hidden": false,
        "group": "database",
        "order": 2
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🐛 Debug Server (TypeScript)",
      "program": "${workspaceFolder}/src/index.ts",
      "runtimeArgs": ["--loader", "tsx/esm"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      },
      "presentation": {
        "hidden": false,
        "group": "debug",
        "order": 1
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🧪 Debug Single Test File",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "hidden": false,
        "group": "debug",
        "order": 2
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🔧 Custom Port (3003)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_OPTIONS": "--inspect",
        "PORT": "3003"
      },
      "presentation": {
        "hidden": false,
        "group": "server",
        "order": 3
      }
    }
  ],
  "compounds": [
    {
      "name": "🚀 Full Stack Development",
      "configurations": [
        "🚀 Dev Server (npm run dev)",
        "🗄️ Prisma Studio"
      ],
      "presentation": {
        "hidden": false,
        "group": "compound",
        "order": 1
      }
    },
    {
      "name": "🧪 Development with Tests",
      "configurations": [
        "🚀 Dev Server (npm run dev)",
        "🔍 Run Tests (Watch Mode)"
      ],
      "presentation": {
        "hidden": false,
        "group": "compound",
        "order": 2
      }
    }
  ]
}